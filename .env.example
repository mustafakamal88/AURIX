AURIX_RUNTIME_PROFILE=LOCAL_DEV
AURIX_HOST=127.0.0.1
AURIX_PORT=8765
AURIX_PUBLIC_BASE_URL=
AURIX_DASHBOARD_READ_ONLY=true
AURIX_REQUIRE_API_KEY_FOR_REMOTE=true
AURIX_API_KEY=
AURIX_SYMBOL=XAUUSDm
AURIX_TERMINAL_ID=AURIX-VPS-001
AURIX_BROKER_EXECUTION=false
AURIX_DATA_DIR=data
AURIX_LOG_DIR=logs
AURIX_RELOAD=false

